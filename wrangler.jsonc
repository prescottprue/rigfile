{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vehicle-work-log",
  "compatibility_date": "2026-01-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "observability": {
    "enabled": true
  },
  // Hyperdrive pools TCP Postgres connections from Workers. Create with:
  //   wrangler hyperdrive create vehicle-work-log-db --connection-string="$NEON_URL"
  // Then paste the returned id below.
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      // REPLACE WITH YOUR HYPERDRIVE ID FROM NEON
      "id": "d0a95e6693424f2e9f3e9bb7f1af4b19",
      // In dev, wrangler/miniflare routes Hyperdrive requests to this URL so
      // the local Postgres from `npm run docker:dev` stands in for Neon.
      "localConnectionString": "postgresql://postgres:postgres@localhost:5440/vehicle_work_log"
    }
  ],
  // R2 bucket holds avatar uploads. Create with:
  //   wrangler r2 bucket create vehicle-work-log-uploads
  "r2_buckets": [
    {
      // REPLACE WITH YOUR R2_BUCKET NAME FROM CLOUDFLARE
      "bucket_name": "vehicle-work-log-prod-uploads",
      "binding": "UPLOADS"
    }
  ],
  // Workers AI powers in-app receipt scans (Scan Bay phase 2). The default
  // vision model lives in app/scan/extract.server.ts; set a SCAN_MODEL var
  // to override without a deploy. There is no local simulator, so the
  // binding is remote-only — in dev it stays OFF unless you opt in with
  // CF_REMOTE_BINDINGS=1 (requires `wrangler login`); without it, in-app
  // scans fall back to local Ollama, same as the batch CLI.
  "ai": {
    "binding": "AI",
    "remote": true
  }
  // SESSION_SECRET is a Wrangler secret. Set with:
  //   wrangler secret put SESSION_SECRET
}
