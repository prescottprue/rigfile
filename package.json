{
  "name": "vehicle-work-log",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "vite dev",
    "build": "vite build",
    "build:node": "DEPLOY_TARGET=node vite build && nitro build",
    "start": "node .output/server/index.mjs",
    "deploy:cf": "npm run build && npx wrangler deploy",
    "typecheck": "tsr generate && tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --env-file=.env --import tsx app/db/seed.ts",
    "docker:dev": "docker compose up -d",
    "docker:build": "docker build -t vehicle-work-log:local .",
    "validate": "npm run typecheck && npm run lint && npm run test -- --run"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@tanstack/react-router": "1.168.23",
    "@tanstack/react-start": "1.167.42",
    "bcryptjs": "^3.0.0",
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@faker-js/faker": "10.4.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-cli": "1.166.33",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.0",
    "happy-dom": "^16.0.0",
    "lefthook": "2.1.6",
    "nitro": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^3.0.0"
  }
}
